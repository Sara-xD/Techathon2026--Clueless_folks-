# HTTP port for the REST + WebSocket server
PORT=4000

# Comma-separated list of origins allowed to call the API / connect via WebSocket
CORS_ORIGIN=http://localhost:5173

# --- Simulator clock ---
# Real milliseconds between simulator ticks (state re-evaluation)
SIM_TICK_MS=4000

# How many simulated seconds pass per real second.
# 60 means 1 real minute = 1 simulated hour, so office-hours/2-hour alert
# rules become observable within minutes during a live demo instead of
# waiting on a real wall clock.
SIM_SPEED_MULTIPLIER=60

# Simulated clock start time (24h). Chosen close to 17:00 (office close)
# on purpose so the "after hours" alert condition is reachable within the
# first minute of a demo.
SIM_START_HOUR=16
SIM_START_MINUTE=30
