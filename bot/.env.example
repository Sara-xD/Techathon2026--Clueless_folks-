# Shared backend the bot pulls live device/usage/alert data from -- the
# same backend the dashboard connects to, so both always agree.
BACKEND_URL=http://localhost:4000

# Command prefix for chat commands (!status, !room <name>, !usage)
COMMAND_PREFIX=!

# --- Discord (optional) ---
# Leave DISCORD_BOT_TOKEN empty to run the local mock CLI instead of a real
# Discord connection -- useful for demoing/testing without setting up a
# Discord Application first. Fill both in to run as a real bot.
DISCORD_BOT_TOKEN=
# Channel ID the bot proactively posts alert messages to (bonus feature).
DISCORD_ALERT_CHANNEL_ID=
# How often (ms) the bot polls the backend for new alerts to announce.
ALERT_POLL_MS=8000

# --- LLM (optional) ---
# Gemini API key used to turn raw device data into a friendly reply.
# Leave empty to fall back to hand-written templates (still satisfies the
# "real answers from real data, humanized" requirement, just without an
# LLM in the loop).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
